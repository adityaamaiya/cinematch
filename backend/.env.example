# --- CineMatch backend config ---
# Copy to `.env` and fill in. NEVER commit the real .env.

# TMDB (https://www.themoviedb.org/settings/api). The v4 read-access token is preferred;
# calls send it as a Bearer token. The v3 API key is kept as a fallback.
TMDB_API_KEY=your_api_key_here
TMDB_READ_ACCESS_TOKEN=your_read_access_token_here

# MongoDB connection string. Create a free M0 cluster on MongoDB Atlas (Phase 6 walks
# through it) and paste the SRV string here.
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/cinematch?retryWrites=true&w=majority

# HTTP port the API listens on.
PORT=3000

# Shared secret required as a Bearer token on POST /sync-profile. Generate any long random
# string; the scraper (and seed script) must send the SAME value.
SYNC_TOKEN=change_me_to_a_long_random_string
