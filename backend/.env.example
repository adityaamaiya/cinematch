# --- CineMatch backend config ---
# Copy to `.env` and fill in. NEVER commit the real .env.

# TMDB (https://www.themoviedb.org/settings/api). The v4 read-access token is preferred;
# calls send it as a Bearer token. The v3 API key is kept as a fallback.
TMDB_API_KEY=your_api_key_here
TMDB_READ_ACCESS_TOKEN=your_read_access_token_here

# MongoDB connection string. Create a free M0 cluster on MongoDB Atlas (Phase 6 walks
# through it) and paste the SRV string here.
MONGODB_URI=mongodb+srv://user:pass@cluster.example.mongodb.net/cinematch?retryWrites=true&w=majority

# HTTP port the API listens on.
PORT=3000

# Shared secret required as a Bearer token on POST /sync-profile. Generate any long random
# string; the scraper (and seed script) must send the SAME value.
SYNC_TOKEN=change_me_to_a_long_random_string

# Optional — OMDb API key (free: https://www.omdbapi.com/apikey.aspx). Enables the awards +
# IMDb-rating line on /score. Leave empty to disable (that data is simply omitted).
OMDB_API_KEY=

# Optional — Google Gemini API key (free: https://aistudio.google.com/apikey). Enables the LLM
# taste line + recommendations (reasons about tone/themes from your ratings). Empty → no taste line.
# GEMINI_MODEL is a comma-separated fallback chain (each free model has its own daily quota).
GEMINI_API_KEY=
GEMINI_MODEL=gemini-flash-lite-latest,gemini-2.5-flash

# Optional — Groq API key (free: https://console.groq.com/keys), the cross-provider fallback tried
# after every Gemini model is quota-exhausted. Much higher free daily limits. Empty → Gemini only.
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Optional — your "home" languages (comma-separated ISO 639-1), used to break same-name-title ties
# toward what you watch. Home languages rank first, then English, then everything else. Defaults to
# an Indian-language set; set your own region's codes if different.
HOME_LANGUAGES=hi,ta,te,ml,kn,bn,mr,pa,gu,or,as,ur

# Only used by `npm run seed` (the local seed script) to reach this API. Defaults to
# http://localhost:$PORT if unset.
BACKEND_URL=http://localhost:3000
