{
  "name": "cinematch-scraper",
  "version": "0.1.0",
  "private": true,
  "description": "Local Playwright scraper — syncs your Moctale reviews + watchlist to the CineMatch backend. Runs on your machine only.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "scrape": "tsx src/scrape.ts",
    "postinstall": "playwright install chromium",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test src/*.test.ts"
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "playwright": "^1.45.0"
  },
  "devDependencies": {
    "@types/node": "^20.14.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0"
  }
}
