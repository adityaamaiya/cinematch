# --- CineMatch scraper config (runs on your Mac only) ---
# Copy to `.env` and fill in. NO Moctale credentials here — login is done manually in a real
# browser window the first time (Cloudflare blocks scripted login); the session is then saved
# in scraper/.moctale-session/ and reused.

# Where to POST the scraped profile.
BACKEND_URL=http://localhost:3000

# Must match SYNC_TOKEN in the backend .env — sent as a Bearer token on /sync-profile.
SYNC_TOKEN=change_me_to_a_long_random_string

# Your Moctale reviews page.
MOCTALE_PROFILE_URL=https://www.moctale.in/u/aditya_amaiya

# Your watchlist collection pages, comma-separated.
MOCTALE_WATCHLIST_URLS=https://www.moctale.in/explore/collection/9MLFJ3ME,https://www.moctale.in/explore/collection/NID7YK88
